# ─────────────────────────────────────────────────
#  Copie ce fichier en .env et ajuste les valeurs
# ─────────────────────────────────────────────────

# Nom du modèle exposé par ton endpoint
LLM_MODEL=mistral

# ── CAS 1 : LLM sur la même machine que Docker ──
# Ollama / LM Studio en local
LLM_BASE_URL=http://host.docker.internal:11434

# ── CAS 2 : LLM sur une autre machine du réseau local ──
# Remplace par l'IP LAN de la machine qui héberge le LLM
# LLM_BASE_URL=http://192.168.1.42:11434

# ── CAS 3 : API distante compatible OpenAI ──
# Groq (rapide, gratuit jusqu'à un certain quota)
# LLM_BASE_URL=https://api.groq.com/openai
# LLM_MODEL=llama3-8b-8192

# OpenAI
# LLM_BASE_URL=https://api.openai.com
# LLM_MODEL=gpt-4o-mini

# Mistral AI
# LLM_BASE_URL=https://api.mistral.ai
# LLM_MODEL=mistral-small-latest

# OpenRouter (accès multi-modèles)
# LLM_BASE_URL=https://openrouter.ai/api
# LLM_MODEL=meta-llama/llama-3-8b-instruct

# ── Clé API ──
# Obligatoire pour les APIs distantes (cas 3), ignorée en local (cas 1 & 2)
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
